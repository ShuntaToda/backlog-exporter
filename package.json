{
  "name": "backlog-exporter",
  "description": "A new CLI generated with oclif",
  "version": "0.7.3",
  "author": "ShuntaToda",
  "bin": {
    "backlog-exporter": "bin/run.js"
  },
  "bugs": "https://github.com/ShuntaToda/backlog-exporter/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.88",
    "@oclif/plugin-plugins": "^5"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/node": "^22.20.0",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "oclif": "^4",
    "prettier": "^3.6.2",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/ShuntaToda/backlog-exporter",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "backlog-exporter",
    "dirname": "backlog-exporter",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@oclif/plugin-not-found"
    ],
    "topicSeparator": " ",
    "topics": {
      "update": {
        "description": "Backlogから最新データを取得して更新する"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShuntaToda/backlog-exporter.git"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "postpack": "node -e \"fs.rmSync('oclif.manifest.json',{force:true})\"",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest run",
    "version": "oclif readme && git add README.md",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts"
  },
  "types": "dist/index.d.ts"
}
